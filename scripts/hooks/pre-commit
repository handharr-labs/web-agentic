#!/usr/bin/env bash
# pre-commit hook — auto-updates <!-- N --> section counts in staged reference docs.
# Only fires when .md files under lib/*/reference/ are staged. Silent otherwise.
#
# Install:
#   cp scripts/hooks/pre-commit .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
UPDATER="$REPO_ROOT/scripts/update-ref-counts.sh"

# ── Scope: only staged .md files under lib/*/reference/ ──────────────────────
staged=$(git diff --cached --name-only \
  | grep -E '^lib/.*/reference/.*\.md$' || true)

[ -z "$staged" ] && exit 0

# ── Update counts and re-stage ────────────────────────────────────────────────
echo "Updating reference section counts..."

while IFS= read -r file; do
  "$UPDATER" "$REPO_ROOT/$file"
  git add "$file"
done <<< "$staged"
